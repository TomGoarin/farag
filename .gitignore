# Secrets — ne JAMAIS commit
.env
.env.local
*.pem
*.key

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# Corpus & artéfacts d'ingestion : on garde les dossiers (via .gitkeep) mais pas leur contenu.
data/raw/*
!data/raw/.gitkeep
data/chunks/*
!data/chunks/.gitkeep

# Dossier historique de docs source (avant convention data/raw)
files/

# Cache HF / modèles téléchargés (au cas où)
.cache/

# Scripts de diagnostic locaux
debug_*.py

# OS / IDE
.DS_Store
.idea/
.vscode/
